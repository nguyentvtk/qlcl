# ============================================================
# SITE360 - Biến môi trường Backend
# Copy file này thành .env và điền giá trị thực
# ============================================================

# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site360
DB_USER=site360_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# JWT Configuration
# Tạo secret bằng: openssl rand -base64 64
JWT_ACCESS_SECRET=your_jwt_access_secret_min_64_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# CORS - Danh sách domain được phép (phân cách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (cho redirect sau auth)
FRONTEND_URL=http://localhost:3000
