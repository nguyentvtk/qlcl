# ════════════════════════════════════════════════════
# Site360 — Quản lý hiện trường — Environment Variables
# Copy file này thành .env và điền giá trị thực tế
# ════════════════════════════════════════════════════

# URL Google Apps Script Web App (CPM 5.0)
# Lấy tại: Apps Script → Deploy → Manage deployments → Web app URL
# Ví dụ: https://script.google.com/macros/s/AKfycb.../exec
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# (Tùy chọn) URL Express backend để upload file ảnh trực tiếp
# Bỏ trống nếu chỉ dùng URL (Google Drive, CDN...)
# Ví dụ: https://site360-api.railway.app/api/v1
VITE_API_URL=
