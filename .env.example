# ============================================================
# SITE360 - Docker Compose Environment Variables
# Copy thành .env và điền giá trị thực
# ============================================================

# Database password (dùng password mạnh, ít nhất 20 ký tự)
DB_PASSWORD=YourVeryStrongPassword123!@#

# JWT Secrets - TẠO BẰNG LỆNH NÀY:
# openssl rand -base64 64
JWT_ACCESS_SECRET=your_64_char_random_access_secret_here
JWT_REFRESH_SECRET=your_64_char_random_refresh_secret_here

# CORS - Domain frontend được phép gọi API
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
